rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User profile
    function isValidUser(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 100
        && (data.lastLoginAt == null || (data.lastLoginAt is string && data.lastLoginAt.size() <= 100));
    }

    // Match users collection
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Users shouldn't list all other users
      allow create: if isEmailVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isEmailVerified() && request.auth.uid == userId && isValidUser(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if false; // Users cannot delete their accounts via standard Firestore Client SDK
    }

    // Validation for Game Logs
    function isValidGameLog(data) {
      return data.logId is string && data.logId.size() <= 64
        && data.userId is string && data.userId == request.auth.uid
        && data.userEmail is string && data.userEmail.size() <= 128 && data.userEmail == request.auth.token.email
        && data.gameName is string && data.gameName.size() <= 32
        && (data.gameName == 'tictactoe' || data.gameName == 'ludo')
        && data.roomId is string && data.roomId.size() <= 64
        && data.outcome is string && data.outcome.size() <= 32
        && (data.outcome == 'won' || data.outcome == 'lost' || data.outcome == 'draw')
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    // Match gameLogs collection
    match /gameLogs/{logId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(logId) && isValidGameLog(incoming());
      allow update, delete: if false; // Logs are write-once, immutable
    }
  }
}
